    auto start = std::chrono::high_resolution_clock::now();
    
    const int n = 1000000;
    double a = 0.0, b = 1.0;
    double h = (b - a) / n;
    
    double trapezoidal = (func50(a) + func50(b)) / 2.0;
    double simpson = func50(a) + func50(b);
    
    for(int i = 1; i < n; i++) {
        double x = a + i * h;
        trapezoidal += func50(x);
        
        if(i % 2 == 0) {
            simpson += 2.0 * func50(x);
        } else {
            simpson += 4.0 * func50(x);
        }
    }
    
    trapezoidal *= h;
    simpson *= h / 3.0;
    
    double result = (2.0 * simpson + trapezoidal) / 3.0;
    
    auto end = std::chrono::high_resolution_clock::now();
    std::chrono::duration<double> elapsed = end - start;
    
