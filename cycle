**程序48: 数值积分误差估计**

```
#include <iostream>
#include <cmath>
#include <chrono>

double func48(double x) {
    return sin(x) * sin(x);
}

int main() {
    auto start = std::chrono::high_resolution_clock::now();
    
    const int n = 1000000;
    double a = 0.0, b = M_PI;
    double h = (b - a) / n;
    
    double trapezoidal = (func48(a) + func48(b)) / 2.0;
    double midpoint = 0.0;
    
    for(int i = 1; i < n; i++) {
        double x = a + i * h;
        trapezoidal += func48(x);
        
        double x_mid = a + (i - 0.5) * h;
        midpoint += func48(x_mid);
    }
    
    trapezoidal *= h;
    midpoint *= h;
    
    double error_estimate = fabs(trapezoidal - midpoint) / 3.0;
    double result = (2.0 * trapezoidal + midpoint) / 3.0;
    
    auto end = std::chrono::high_resolution_clock::now();
    std::chrono::duration<double> elapsed = end - start;
    
    std::cout << "程序48 - 数值积分误差估计" << std::endl;
    std::cout << "积分值: " << result << std::endl;
    std::cout << "误差估计: " << error_estimate << std::endl;
    std::cout << "运行时间: " << elapsed.count() << "秒" << std::endl;
    
    return 0;
}
