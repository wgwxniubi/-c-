## 程序1: 辛普森积分法

```
#include <iostream>
#include <cmath>
#include <chrono>

double func1(double x) {
    return sin(x);
}

int main() {
    auto start = std::chrono::high_resolution_clock::now();
    
    const int n = 1000000;
    double a = 0.0, b = 1.0;
    double h = (b - a) / n;
    double sum = 0.0;
    
    sum = func1(a) + func1(b);
    for(int i = 1; i < n; i++) {
        double x = a + i * h;
        if(i % 2 == 0) {
            sum += 2.0 * func1(x);
        } else {
            sum += 4.0 * func1(x);
        }
    }
    sum *= h / 3.0;
    
    auto end = std::chrono::high_resolution_clock::now();
    std::chrono::duration<double> elapsed = end - start;
    
    std::cout << "程序1 - 辛普森积分: ∫sin(x)dx (0→1) = " << sum << std::endl;
    std::cout << "理论值: " << 1.0 - cos(1.0) << std::endl;
    std::cout << "运行时间: " << elapsed.count() << "秒" << std::endl;
    
    return 0;
}
```

## 程序2: 梯形积分法

```
#include <iostream>
#include <cmath>
#include <chrono>

double func2(double x) {
    return exp(-x * x);
}

int main() {
    auto start = std::chrono::high_resolution_clock::now();
    
    const int n = 1000000;
    double a = 0.0, b = 2.0;
    double h = (b - a) / n;
    double sum = 0.0;
    
    sum = (func2(a) + func2(b)) / 2.0;
    for(int i = 1; i < n; i++) {
        double x = a + i * h;
        sum += func2(x);
    }
    sum *= h;
    
    auto end = std::chrono::high_resolution_clock::now();
    std::chrono::duration<double> elapsed = end - start;
    
    std::cout << "程序2 - 梯形积分: ∫exp(-x²)dx (0→2) = " << sum << std::endl;
    std::cout << "运行时间: " << elapsed.count() << "秒" << std::endl;
    
    return 0;
}
```

## 程序3: 计算π（蒙特卡洛方法）

```
#include <iostream>
#include <cmath>
#include <cstdlib>
#include <ctime>
#include <chrono>

int main() {
    auto start = std::chrono::high_resolution_clock::now();
    
    const int n = 1000000;
    int inside_circle = 0;
    
    std::srand(std::time(0));
    for(int i = 0; i < n; i++) {
        double x = static_cast<double>(rand()) / RAND_MAX;
        double y = static_cast<double>(rand()) / RAND_MAX;
        
        if(x * x + y * y <= 1.0) {
            inside_circle++;
        }
    }
    
    double pi_estimate = 4.0 * inside_circle / n;
    
    auto end = std::chrono::high_resolution_clock::now();
    std::chrono::duration<double> elapsed = end - start;
    
    std::cout << "程序3 - 蒙特卡洛法计算π: " << pi_estimate << std::endl;
    std::cout << "实际π值: " << M_PI << std::endl;
    std::cout << "运行时间: " << elapsed.count() << "秒" << std::endl;
    
    return 0;
}
```

