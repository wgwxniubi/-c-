**程序44: 自适应辛普森积分法**

```
#include <iostream>
#include <cmath>
#include <chrono>

double func44(double x) {
    return sin(x) / x;
}

double adaptive_simpson(double a, double b, double tol, int depth) {
    double c = (a + b) / 2.0;
    double h = b - a;
    
    double fa = func44(a);
    double fb = func44(b);
    double fc = func44(c);
    
    double S = (h / 6.0) * (fa + 4.0 * fc + fb);
    double S1 = (h / 12.0) * (fa + 4.0 * func44((a + c) / 2.0) + fc);
    double S2 = (h / 12.0) * (fc + 4.0 * func44((c + b) / 2.0) + fb);
    
    if (fabs(S1 + S2 - S) < 15.0 * tol || depth <= 0) {
        return S1 + S2 + (S1 + S2 - S) / 15.0;
    }
    
    return adaptive_simpson(a, c, tol/2.0, depth-1) + 
           adaptive_simpson(c, b, tol/2.0, depth-1);
}

int main() {
    auto start = std::chrono::high_resolution_clock::now();
    
    double a = 0.000001, b = 1.0;
    double tol = 1e-8;
    int max_depth = 20;
    
    double result = adaptive_simpson(a, b, tol, max_depth);
    
    auto end = std::chrono::high_resolution_clock::now();
    std::chrono::duration<double> elapsed = end - start;
    
    std::cout << "程序44 - 自适应辛普森积分: ∫sin(x)/x dx (0→1) = " << result << std::endl;
    std::cout << "运行时间: " << elapsed.count() << "秒" << std::endl;
    
    return 0;
}
