    std::cout << "最低温度: " << min_temperature << " °C" << std::endl;
    std::cout << "平均温度: " << average_temperature << " °C" << std::endl;
    std::cout << "最大误差: " << max_error << " °C" << std::endl;
    std::cout << "平均误差: " << average_error << " °C" << std::endl;
    std::cout << "RMS误差: " << rms_error << " °C" << std::endl;
    
    std::cout << "\n=== 热流分析 ===" << std::endl;
    std::cout << "平均热流密度: " << flux_magnitude_sum / active_cells << " W/m²" << std::endl;
    std::cout << "最大热应力: " << stress_magnitude_sum / active_cells << " Pa" << std::endl;
    
    std::cout << "\n=== 能量平衡 ===" << std::endl;
    std::cout << "总热能: " << total_energy << " J" << std::endl;
