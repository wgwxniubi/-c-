    average_velocity = (pipe1_velocity + pipe2_velocity + pipe3_velocity + pipe4_velocity + pipe5_velocity) / 5.0;
    average_diameter = (pipe1_diameter + pipe2_diameter + pipe3_diameter + pipe4_diameter + pipe5_diameter) / 5.0;
    average_flow_rate = (pipe1_flow_rate + pipe2_flow_rate + pipe3_flow_rate + pipe4_flow_rate + pipe5_flow_rate) / 5.0;
    
    // 计算系统雷诺数
    system_reynolds = water_density * average_velocity * average_diameter / water_viscosity;
    
    // 计算等效直径
    equivalent_diameter = sqrt(4.0 * (pipe1_area + pipe2_area + pipe3_area + pipe4_area + pipe5_area) / pi);
    
    // 计算水头
    velocity_head = pow(average_velocity, 2) / (2.0 * gravity);
    pressure_head = 101325.0 / (water_density * gravity);  // 大气压对应的水头
    elevation_head = 10.0;  // 假设高程差10m
    total_head = velocity_head + pressure_head + elevation_head;
    
    // 计算水力梯度
    hydraulic_gradient = total_head_loss / (pipe1_length + pipe2_length + pipe3_length + pipe4_length + pipe5_length);
    
    // 计算空化数
    double vapor_pressure = 2339.0;  // 水的饱和蒸汽压（Pa）
    cavitation_number = (101325.0 - vapor_pressure) / (0.5 * water_density * pow(average_velocity, 2));
    
    // 计算系统效率
    system_efficiency = (total_power_required * pump_efficiency) / (total_power_required + 1000.0);  // 假设额外损失1000W
    
    // 输出结果
    std::cout << std::fixed;
    std::cout.precision(4);
    
    std::cout << "\n管道1结果:" << std::endl;
    std::cout << "流速: " << pipe1_velocity << " m/s" << std::endl;
    std::cout << "雷诺数: " << pipe1_reynolds << std::endl;
    std::cout << "摩擦系数: " << pipe1_friction_factor << std::endl;
    std::cout << "水头损失: " << pipe1_head_loss << " m" << std::endl;
    std::cout << "压降: " << pipe1_pressure_drop / 1000.0 << " kPa" << std::endl;
    std::cout << "所需功率: " << pipe1_power_required << " W" << std::endl;
    
    std::cout << "\n管道2结果:" << std::endl;
    std::cout << "流速: " << pipe2_velocity << " m/s" << std::endl;
    std::cout << "雷诺数: " << pipe2_reynolds << std::endl;
    std::cout << "摩擦系数: " << pipe2_friction_factor << std::endl;
    std::cout << "水头损失: " << pipe2_head_loss << " m" << std::endl;
    std::cout << "压降: " << pipe2_pressure_drop / 1000.0 << " kPa" << std::endl;
    std::cout << "所需功率: " << pipe2_power_required << " W" << std::endl;
    
    std::cout << "\n系统参数:" << std::endl;
    std::cout << "总流量: " << total_flow_rate << " m³/s" << std::endl;
    std::cout << "总水头损失: " << total_head_loss << " m" << std::endl;
    std::cout << "总压降: " << total_pressure_drop / 1000.0 << " kPa" << std::endl;
    std::cout << "总功率需求: " << total_power_required << " W" << std::endl;
    std::cout << "平均流速: " << average_velocity << " m/s" << std::endl;
    std::cout << "平均直径: " << average_diameter << " m" << std::endl;
    std::cout << "系统雷诺数: " << system_reynolds << std::endl;
    std::cout << "等效直径: " << equivalent_diameter << " m" << std::endl;
    std::cout << "水力梯度: " << hydraulic_gradient << std::endl;
    std::cout << "总水头: " << total_head << " m" << std::endl;
    std::cout << "空化数: " << cavitation_number << std::endl;
    std::cout << "系统效率: " << system_efficiency * 100.0 << "%" << std::endl;
    std::cout << "浮点变量总数: 80+" << std::endl;
    
    return 0;
}

