```c
#include <iostream>
#include <cmath>

int main() {
    // 图像参数
    int image_width = 8, image_height = 8;
    double image_data[8][8];
    double filtered_image[8][8];
    
    // 卷积核1：高斯模糊
    double kernel_gaussian[3][3];
    double gaussian_sigma = 1.5;
    double gaussian_sum = 0.0;
    
    // 卷积核2：边缘检测
    double kernel_sobel_x[3][3];
    double kernel_sobel_y[3][3];
    double edge_image_x[8][8];
    double edge_image_y[8][8];
    double edge_magnitude[8][8];
    
    // 卷积核3：锐化
    double kernel_sharpen[3][3];
    double sharpened_image[8][8];
    
    // 统计参数
    double image_mean = 0.0, image_variance = 0.0, image_stddev = 0.0;
    double filtered_mean = 0.0, filtered_variance = 0.0, filtered_stddev = 0.0;
    double edge_mean = 0.0, edge_variance = 0.0, edge_stddev = 0.0;
    double sharpen_mean = 0.0, sharpen_variance = 0.0, sharpen_stddev = 0.0;
    
    // 计算变量
    double total_pixels = image_width * image_height;
    double image_sum = 0.0, image_square_sum = 0.0;
    double filtered_sum = 0.0, filtered_square_sum = 0.0;
    double edge_sum = 0.0, edge_square_sum = 0.0;
    double sharpen_sum = 0.0, sharpen_square_sum = 0.0;
    
    // 实际计算
    std::cout << "=== 图像处理：卷积滤波 ===" << std::endl;
    
    // 生成测试图像（简单的渐变）
    for(int i = 0; i < image_height; i++) {
        for(int j = 0; j < image_width; j++) {
            image_data[i][j] = (i + j) * 10.0;  // 线性渐变
            image_sum += image_data[i][j];
            image_square_sum += image_data[i][j] * image_data[i][j];
        }
    }
    
    // 计算图像统计
    image_mean = image_sum / total_pixels;
    image_variance = (image_square_sum / total_pixels) - (image_mean * image_mean);
    image_stddev = sqrt(image_variance);
    
    // 生成高斯卷积核
    for(int i = -1; i <= 1; i++) {
        for(int j = -1; j <= 1; j++) {
            double value = exp(-(i*i + j*j) / (2.0 * gaussian_sigma * gaussian_sigma));
            kernel_gaussian[i+1][j+1] = value;
            gaussian_sum += value;
        }
    }
    
    // 归一化高斯核
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            kernel_gaussian[i][j] /= gaussian_sum;
        }
    }
    
    // 生成Sobel算子
    kernel_sobel_x[0][0] = -1; kernel_sobel_x[0][1] = 0; kernel_sobel_x[0][2] = 1;
    kernel_sobel_x[1][0] = -2; kernel_sobel_x[1][1] = 0; kernel_sobel_x[1][2] = 2;
    kernel_sobel_x[2][0] = -1; kernel_sobel_x[2][1] = 0; kernel_sobel_x[2][2] = 1;
    
    kernel_sobel_y[0][0] = -1; kernel_sobel_y[0][1] = -2; kernel_sobel_y[0][2] = -1;
    kernel_sobel_y[1][0] = 0; kernel_sobel_y[1][1] = 0; kernel_sobel_y[1][2] = 0;
    kernel_sobel_y[2][0] = 1; kernel_sobel_y[2][1] = 2; kernel_sobel_y[2][2] = 1;
    
    // 生成锐化卷积核
    kernel_sharpen[0][0] = 0; kernel_sharpen[0][1] = -1; kernel_sharpen[0][2] = 0;
    kernel_sharpen[1][0] = -1; kernel_sharpen[1][1] = 5; kernel_sharpen[1][2] = -1;
    kernel_sharpen[2][0] = 0; kernel_sharpen[2][1] = -1; kernel_sharpen[2][2] = 0;
    
    // 应用高斯滤波
    for(int i = 1; i < image_height-1; i++) {
        for(int j = 1; j < image_width-1; j++) {
            filtered_image[i][j] = 0.0;
            for(int ki = -1; ki <= 1; ki++) {
                for(int kj = -1; kj <= 1; kj++) {
                    filtered_image[i][j] += image_data[i+ki][j+kj] * kernel_gaussian[ki+1][kj+1];
                }
            }
            filtered_sum += filtered_image[i][j];
            filtered_square_sum += filtered_image[i][j] * filtered_image[i][j];
        }
    }
    
    // 计算滤波后统计
    filtered_mean = filtered_sum / total_pixels;
    filtered_variance = (filtered_square_sum / total_pixels) - (filtered_mean * filtered_mean);
    filtered_stddev = sqrt(filtered_variance);
    
    // 应用Sobel边缘检测
    for(int i = 1; i < image_height-1; i++) {
        for(int j = 1; j < image_width-1; j++) {
            double gx = 0.0, gy = 0.0;
            for(int ki = -1; ki <= 1; ki++) {
                for(int kj = -1; kj <= 1; kj++) {
                    gx += image_data[i+ki][j+kj] * kernel_sobel_x[ki+1][kj+1];
                    gy += image_data[i+ki][j+kj] * kernel_sobel_y[ki+1][kj+1];
                }
            }
            edge_image_x[i][j] = gx;
            edge_image_y[i][j] = gy;
            edge_magnitude[i][j] = sqrt(gx*gx + gy*gy);
            edge_sum += edge_magnitude[i][j];
            edge_square_sum += edge_magnitude[i][j] * edge_magnitude[i][j];
        }
    }
    
    // 计算边缘检测统计
    edge_mean = edge_sum / total_pixels;
    edge_variance = (edge_square_sum / total_pixels) - (edge_mean * edge_mean);
    edge_stddev = sqrt(edge_variance);
    
    // 应用锐化滤波
    for(int i = 1; i < image_height-1; i++) {
        for(int j = 1; j < image_width-1; j++) {
            sharpened_image[i][j] = 0.0;
            for(int ki = -1; ki <= 1; ki++) {
                for(int kj = -1; kj <= 1; kj++) {
                    sharpened_image[i][j] += image_data[i+ki][j+kj] * kernel_sharpen[ki+1][kj+1];
                }
            }
            sharpen_sum += sharpened_image[i][j];
            sharpen_square_sum += sharpened_image[i][j] * sharpened_image[i][j];
        }
    }
    
    // 计算锐化后统计
    sharpen_mean = sharpen_sum / total_pixels;
    sharpen_variance = (sharpen_square_sum / total_pixels) - (sharpen_mean * sharpen_mean);
    sharpen_stddev = sqrt(sharpen_variance);
    
    // 输出结果
    std::cout << "图像尺寸: " << image_width << "x" << image_height << std::endl;
