## 3. 电力系统负载潮流计算

```c
#include <iostream>
#include <complex>
#include <cmath>
using namespace std;

class PowerFlow {
private:
    static const int BUS_COUNT = 15;
    
public:
    void calculatePowerFlow() {
        // 母线变量
        float bus_voltage[BUS_COUNT], bus_angle[BUS_COUNT];
        float bus_active_power[BUS_COUNT], bus_reactive_power[BUS_COUNT];
        float bus_load_active[BUS_COUNT], bus_load_reactive[BUS_COUNT];
        float bus_generation_active[BUS_COUNT], bus_generation_reactive[BUS_COUNT];
        
        // 线路变量
        float line_resistance[BUS_COUNT][BUS_COUNT];
        float line_reactance[BUS_COUNT][BUS_COUNT];
        float line_conductance[BUS_COUNT][BUS_COUNT];
        float line_susceptance[BUS_COUNT][BUS_COUNT];
        float line_power_flow[BUS_COUNT][BUS_COUNT];
        
        // 变压器变量
        float transformer_tap_ratio[BUS_COUNT][BUS_COUNT];
        float transformer_phase_shift[BUS_COUNT][BUS_COUNT];
        float transformer_impedance[BUS_COUNT][BUS_COUNT];
        
        // 收敛判断变量
        float power_mismatch[BUS_COUNT], voltage_mismatch[BUS_COUNT];
        float max_power_mismatch, max_voltage_mismatch;
        float convergence_tolerance = 1e-6f;
        int iteration_count = 0;
        bool converged = false;
        
        // 初始化电力系统参数
        initializeSystemParameters(bus_voltage, bus_angle, line_resistance, line_reactance);
        
        // 潮流计算迭代
        while(!converged && iteration_count < 100) {
            max_power_mismatch = 0.0f;
            max_voltage_mismatch = 0.0f;
            
            // 计算功率不平衡量
            for(int i = 0; i < BUS_COUNT; i++) {
                power_mismatch[i] = calculatePowerMismatch(i, bus_voltage, bus_angle,
                    line_resistance, line_reactance);
                max_power_mismatch = max(max_power_mismatch, abs(power_mismatch[i]));
            }
            
            // 更新电压和相角
            for(int i = 0; i < BUS_COUNT; i++) {
                float voltage_correction = calculateVoltageCorrection(i, power_mismatch[i]);
                float angle_correction = calculateAngleCorrection(i, power_mismatch[i]);
                
                bus_voltage[i] += voltage_correction;
                bus_angle[i] += angle_correction;
                
                voltage_mismatch[i] = abs(voltage_correction);
                max_voltage_mismatch = max(max_voltage_mismatch, voltage_mismatch[i]);
            }
            
            converged = (max_power_mismatch < convergence_tolerance) && 
                       (max_voltage_mismatch < convergence_tolerance);
            iteration_count++;
            
            cout << "迭代 " << iteration_count << ": 最大功率偏差=" 
                 << max_power_mismatch << endl;
        }
        
        cout << "潮流计算完成，共迭代 " << iteration_count << " 次" << endl;
    }
    
private:
    void initializeSystemParameters(float bus_voltage[], float bus_angle[],
                                   float line_resistance[][BUS_COUNT], 
                                   float line_reactance[][BUS_COUNT]) {
        for(int i = 0; i < BUS_COUNT; i++) {
            bus_voltage[i] = 1.0f;
            bus_angle[i] = 0.0f;
        }
        
        for(int i = 0; i < BUS_COUNT; i++) {
            for(int j = 0; j < BUS_COUNT; j++) {
                line_resistance[i][j] = 0.01f;
                line_reactance[i][j] = 0.1f;
            }
        }
    }
    
    float calculatePowerMismatch(int bus, float bus_voltage[], float bus_angle[],
                                float line_resistance[][BUS_COUNT],
                                float line_reactance[][BUS_COUNT]) {
        return 0.0f; // 简化实现
    }
    
    float calculateVoltageCorrection(int bus, float power_mismatch) {
        return power_mismatch * 0.001f;
    }
    
    float calculateAngleCorrection(int bus, float power_mismatch) {
        return power_mismatch * 0.0001f;
    }
};

int main() {c
    PowerFlow power_flow;
    power_flow.calculatePowerFlow();
    return 0;
}
