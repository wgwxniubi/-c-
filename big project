private:
    void calculateForces() {
        for(int i = 0; i < PARTICLE_COUNT; i++) {
            // 重力
            float gravityX = 0.0f;
            float gravityY = particleMass[i] * externalForceY;
            float gravityZ = 0.0f;
            
            // 电磁力
            float electromagneticX = particleCharge[i] * electricFieldX;
            float electromagneticY = particleCharge[i] * electricFieldY;
            float electromagneticZ = particleCharge[i] * electricFieldZ;
            
            // 粒子间作用力（简化版）
            float interactionX = 0.0f, interactionY = 0.0f, interactionZ = 0.0f;
            for(int j = 0; j < PARTICLE_COUNT; j++) {
                if(i != j) {
                    float dx = particlePositionX[j] - particlePositionX[i];
                    float dy = particlePositionY[j] - particlePositionY[i];
                    float dz = particlePositionZ[j] - particlePositionZ[i];
                    float distanceSq = dx*dx + dy*dy + dz*dz + 0.01f; // 避免除零
                    float distance = sqrtf(distanceSq);
                    
                    // 万有引力
                    float gravityForce = gravitationalConstant * particleMass[i] * particleMass[j] / distanceSq;
                    interactionX += gravityForce * dx / distance;
                    interactionY += gravityForce * dy / distance;
                    interactionZ += gravityForce * dz / distance;
                    
                    // 库仑力
                    float coulombForce = coulombConstant * particleCharge[i] * particleCharge[j] / distanceSq;
                    interactionX += coulombForce * dx / distance;
                    interactionY += coulombForce * dy / distance;
                    interactionZ += coulombForce * dz / distance;
                }
            }
            
            // 总力
            forceFieldX[i] = gravityX + electromagneticX + interactionX;
            forceFieldY[i] = gravityY + electromagneticY + interactionY;
            forceFieldZ[i] = gravityZ + electromagneticZ + interactionZ;
            
            // 加速度
            particleAccelerationX[i] = forceFieldX[i] / particleMass[i];
            particleAccelerationY[i] = forceFieldY[i] / particleMass[i];
            particleAccelerationZ[i] = forceFieldZ[i] / particleMass[i];
        }
    }
    
    void integrateMotion() {
        for(int i = 0; i < PARTICLE_COUNT; i++) {
            // 速度更新
            particleVelocityX[i] += particleAccelerationX[i] * timeStep;
            particleVelocityY[i] += particleAccelerationY[i] * timeStep;
            particleVelocityZ[i] += particleAccelerationZ[i] * timeStep;
            
            // 位置更新
            particlePositionX[i] += particleVelocityX[i] * timeStep;
            particlePositionY[i] += particleVelocityY[i] * timeStep;
            particlePositionZ[i] += particleVelocityZ[i] * timeStep;
        }
    }
    
    void handleCollisions() {
        for(int i = 0; i < PARTICLE_COUNT; i++) {
            // 边界碰撞处理
            if(particlePositionX[i] < boundaryMinX) {
                particlePositionX[i] = boundaryMinX;
                particleVelocityX[i] = -restitutionCoefficient * particleVelocityX[i];
            }
            if(particlePositionX[i] > boundaryMaxX) {
                particlePositionX[i] = boundaryMaxX;
                particleVelocityX[i] = -restitutionCoefficient * particleVelocityX[i];
            }
            // 类似处理Y和Z方向
        }
    }
    
    void calculateEnergyAndMomentum(int step) {
        kineticEnergy[step] = 0.0f;
        potentialEnergy[step] = 0.0f;
        momentumX[step] = 0.0f;
        momentumY[step] = 0.0f;
        momentumZ[step] = 0.0f;
        
        for(int i = 0; i < PARTICLE_COUNT; i++) {
            float speedSq = particleVelocityX[i]*particleVelocityX[i] + 
                           particleVelocityY[i]*particleVelocityY[i] + 
                           particleVelocityZ[i]*particleVelocityZ[i];
            kineticEnergy[step] += 0.5f * particleMass[i] * speedSq;
            
            momentumX[step] += particleMass[i] * particleVelocityX[i];
            momentumY[step] += particleMass[i] * particleVelocityY[i];
            momentumZ[step] += particleMass[i] * particleVelocityZ[i];
        }
        
        totalEnergy[step] = kineticEnergy[step] + potentialEnergy[step];
    }
    
    void displayResults() {
        std::cout << "=== 物理粒子系统仿真结果 ===" << std::endl;
        std::cout << "粒子数量: " << PARTICLE_COUNT << std::endl;
