    }
    
    void initializeSystem() {
        // 初始化原子位置（简单立方格子）
        int atomsPerSide = 4;  // 4x4x4 = 64原子
        float latticeConstant = boxSizeX / atomsPerSide;
        int atomIndex = 0;
        
        for(int i = 0; i < atomsPerSide && atomIndex < ATOMS_COUNT; i++) {
