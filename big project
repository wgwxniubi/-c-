    void runSimulation() {
        for(int step = 0; step < SIMULATION_STEPS; step++) {
            calculateForces();
            integrateMotion();
            handleCollisions();
            calculateEnergyAndMomentum(step);
            currentStep++;
            simulationTime += timeStep;
        }
        displayResults();
