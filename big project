    // 积分算法参数
    float verletPositionX[ATOMS_COUNT];
    float verletPositionY[ATOMS_COUNT];
    float verletPositionZ[ATOMS_COUNT];
    float predictorCorrectorCoeffs[5];
    
    // 分析变量
