    // 网格参数
    int nx = 12, ny = 12;                  // 网格点数
    double dx = plate_length_x / (nx - 1); // x方向步长
    double dy = plate_length_y / (ny - 1); // y方向步长
    
    // 温度场变量 (144个变量)
    double temperature_old[12][12];       // 上一时间步温度
    double temperature_new[12][12];         // 当前时间步温度
    double temperature_analytical[12][12]; // 解析解
    double temperature_error[12][12];       // 误差
    
    // 边界条件
    double left_boundary_temp = 100.0;      // 左边温度 (°C)
    double right_boundary_temp = 50.0;      // 右边温度 (°C)
    double top_boundary_temp = 75.0;        // 上边温度 (°C)
    double bottom_boundary_temp = 25.0;     // 下边温度 (°C)
    double initial_temperature = 20.0;      // 初始温度 (°C)
    
    // 热源参数
    double heat_source_intensity = 1000.0;  // 热源强度 (W/m³)
    double heat_source_x = 0.3;             // 热源x位置
    double heat_source_y = 0.7;              // 热源y位置
    double heat_source_radius = 0.1;         // 热源半径
    
    // 计算参数
    double time_step = 0.1;                 // 时间步长 (s)
    double total_time = 10.0;               // 总时间 (s)
    double convergence_tolerance = 1e-6;    // 收敛容差
    int max_iterations = 1000;              // 最大迭代次数
    
    // 监测变量
    double max_temperature = 0.0, min_temperature = 0.0, average_temperature = 0.0;
    double max_error = 0.0, average_error = 0.0, rms_error = 0.0;
    double heat_flux_x[12][12], heat_flux_y[12][12];  // 热流密度
    double temperature_gradient_x[12][12], temperature_gradient_y[12][12];
    double thermal_stress_xx[12][12], thermal_stress_yy[12][12], thermal_stress_xy[12][12];
    
    // 材料热应力参数
    double youngs_modulus = 1.1e11;        // 杨氏模量 (Pa)
    double poissons_ratio = 0.34;           // 泊松比
    double thermal_expansion = 1.7e-5;      // 热膨胀系数 (1/K)
    
    // 能量参数
    double total_energy = 0.0, energy_change = 0.0, heat_generation = 0.0;
    double heat_loss_boundary = 0.0, energy_balance_error = 0.0;
    
    // 收敛监测
    double residual_history[1000], error_history[1000];
    double convergence_rate = 0.0, stability_criterion = 0.0;
    
    // 统计变量
    double temperature_sum = 0.0, error_sum = 0.0, error_square_sum = 0.0;
    double flux_magnitude_sum = 0.0, stress_magnitude_sum = 0.0;
    int active_cells = 0, convergence_iterations = 0;
    
    // 性能监测
    double computation_time = 0.0, memory_usage = 0.0;
    double flops_count = 0.0, memory_bandwidth = 0.0;
    
    std::cout << "=== 二维稳态热传导方程求解 ===" << std::endl;
    std::cout << "网格尺寸: " << nx << " × " << ny << " = " << nx * ny << " 个节点" << std::endl;
    std::cout << "浮点变量总数: 50+" << std::endl;
    
    // 初始化温度场
    for (int i = 0; i < nx; i++) {
        for (int j = 0; j < ny; j++) {
            temperature_old[i][j] = initial_temperature;
            temperature_new[i][j] = initial_temperature;
        }
    }
    
    // 设置边界条件
    for (int j = 0; j < ny; j++) {
        temperature_old[0][j] = left_boundary_temp;        // 左边界
        temperature_old[nx-1][j] = right_boundary_temp;    // 右边界
        temperature_new[0][j] = left_boundary_temp;
        temperature_new[nx-1][j] = right_boundary_temp;
    }
    
    for (int i = 0; i < nx; i++) {
        temperature_old[i][0] = bottom_boundary_temp;     // 下边界
        temperature_old[i][ny-1] = top_boundary_temp;      // 上边界
        temperature_new[i][0] = bottom_boundary_temp;
        temperature_new[i][ny-1] = top_boundary_temp;
    }
    
    // 迭代求解
    double max_residual = 0.0;
    int iter = 0;
    
    for (iter = 0; iter < max_iterations; iter++) {
        max_residual = 0.0;
        
        // 高斯-赛德尔迭代
        for (int i = 1; i < nx - 1; i++) {
            for (int j = 1; j < ny - 1; j++) {
                // 计算热源项
                double x_pos = i * dx;
                double y_pos = j * dy;
                double distance_to_source = sqrt(pow(x_pos - heat_source_x, 2) + 
                                               pow(y_pos - heat_source_y, 2));
                double source_term = 0.0;
                
                if (distance_to_source <= heat_source_radius) {
                    source_term = heat_source_intensity * 
                                (1.0 - distance_to_source / heat_source_radius);
                }
                
                // 有限差分计算
                temperature_new[i][j] = 0.25 * (
                    temperature_old[i+1][j] + temperature_old[i-1][j] +
                    temperature_old[i][j+1] + temperature_old[i][j-1] +
                    source_term * dx * dy / thermal_conductivity
                );
                
                // 计算残差
                double residual = fabs(temperature_new[i][j] - temperature_old[i][j]);
                if (residual > max_residual) {
                    max_residual = residual;
                }
            }
        }
        
        residual_history[iter] = max_residual;
        
        // 检查收敛
        if (max_residual < convergence_tolerance && iter > 10) {
            convergence_iterations = iter + 1;
            break;
        }
        
        // 更新温度场
        for (int i = 1; i < nx - 1; i++) {
            for (int j = 1; j < ny - 1; j++) {
                temperature_old[i][j] = temperature_new[i][j];
            }
        }
    }
    
    // 计算热流密度
    for (int i = 1; i < nx - 1; i++) {
        for (int j = 1; j < ny - 1; j++) {
            heat_flux_x[i][j] = -thermal_conductivity * 
                               (temperature_new[i+1][j] - temperature_new[i-1][j]) / (2.0 * dx);
            heat_flux_y[i][j] = -thermal_conductivity * 
                               (temperature_new[i][j+1] - temperature_new[i][j-1]) / (2.0 * dy);
        }
    }
    
    // 计算温度梯度
    for (int i = 1; i < nx - 1; i++) {
        for (int j = 1; j < ny - 1; j++) {
            temperature_gradient_x[i][j] = (temperature_new[i+1][j] - temperature_new[i-1][j]) / (2.0 * dx);
            temperature_gradient_y[i][j] = (temperature_new[i][j+1] - temperature_new[i][j-1]) / (2.0 * dy);
        }
    }
    
    // 计算热应力
    double stress_factor = youngs_modulus * thermal_expansion / (1.0 - poissons_ratio);
    
    for (int i = 0; i < nx; i++) {
        for (int j = 0; j < ny; j++) {
            double delta_temp = temperature_new[i][j] - initial_temperature;
            thermal_stress_xx[i][j] = stress_factor * delta_temp;
            thermal_stress_yy[i][j] = stress_factor * delta_temp;
            thermal_stress_xy[i][j] = 0.0;  // 简化假设
        }
    }
    
    // 统计计算
    max_temperature = temperature_new[0][0];
    min_temperature = temperature_new[0][0];
    temperature_sum = 0.0;
    active_cells = 0;
    
    for (int i = 0; i < nx; i++) {
        for (int j = 0; j < ny; j++) {
            double temp = temperature_new[i][j];
            
            // 统计温度
            if (temp > max_temperature) max_temperature = temp;
            if (temp < min_temperature) min_temperature = temp;
            temperature_sum += temp;
            
            // 统计热流
            flux_magnitude_sum += sqrt(pow(heat_flux_x[i][j], 2) + pow(heat_flux_y[i][j], 2));
            
            // 统计应力
            stress_magnitude_sum += sqrt(pow(thermal_stress_xx[i][j], 2) + 
                                       pow(thermal_stress_yy[i][j], 2) +
                                       pow(thermal_stress_xy[i][j], 2));
            
            active_cells++;
        }
    }
    
    average_temperature = temperature_sum / active_cells;
    
    // 计算解析解（简化情况下的近似解）
    for (int i = 0; i < nx; i++) {
        for (int j = 0; j < ny; j++) {
            double x = i * dx;
            double y = j * dy;
            
            // 简化解析解（实际应用需要根据具体边界条件推导）
            temperature_analytical[i][j] = left_boundary_temp + 
                                          (right_boundary_temp - left_boundary_temp) * x / plate_length_x +
                                          (top_boundary_temp - bottom_boundary_temp) * y / plate_length_y;
            
            temperature_error[i][j] = fabs(temperature_new[i][j] - temperature_analytical[i][j]);
            error_sum += temperature_error[i][j];
            error_square_sum += pow(temperature_error[i][j], 2);
            
            if (temperature_error[i][j] > max_error) {
                max_error = temperature_error[i][j];
            }
        }
    }
    
    average_error = error_sum / active_cells;
    rms_error = sqrt(error_square_sum / active_cells);
    
    // 计算能量平衡
    total_energy = temperature_sum * density * specific_heat * dx * dy * thickness;
    heat_generation = heat_source_intensity * M_PI * pow(heat_source_radius, 2) * thickness;
    
    // 输出结果
    std::cout << std::fixed << std::setprecision(4);
