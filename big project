private:
    void calculateForces() {
        // 清零力数组
        for(int i = 0; i < ATOMS_COUNT; i++) {
            atomForcesX[i] = 0.0f;
            atomForcesY[i] = 0.0f;
            atomForcesZ[i] = 0.0f;
            atomEnergies[i] = 0.0f;
        }
        
        // 计算对势
        for(int i = 0; i < ATOMS_COUNT; i++) {
            for(int j = i + 1; j < ATOMS_COUNT; j++) {
                float dx = atomPositionsX[j] - atomPositionsX[i];
                float dy = atomPositionsY[j] - atomPositionsY[i];
                float dz = atomPositionsZ[j] - atomPositionsZ[i];
                
                // 周期性边界条件
                if(periodicBoundary) {
                    dx -= boxSizeX * roundf(dx / boxSizeX);
                    dy -= boxSizeY * roundf(dy / boxSizeY);
                    dz -= boxSizeZ * roundf(dz / boxSizeZ);
                }
                
                float r2 = dx*dx + dy*dy + dz*dz;
                
                if(r2 < cutoffDistance * cutoffDistance) {
                    float r = sqrtf(r2);
                    
                    // Lennard-Jones势
                    float sigmaOverR = lennardJonesSigma / r;
                    float sigmaOverR6 = powf(sigmaOverR, 6.0f);
                    float sigmaOverR12 = sigmaOverR6 * sigmaOverR6;
                    
                    float ljEnergy = 4.0f * lennardJonesEpsilon * (sigmaOverR12 - sigmaOverR6);
                    float ljForce = 24.0f * lennardJonesEpsilon * (2.0f * sigmaOverR12 - sigmaOverR6) / r;
                    
                    // Coulomb势
                    float coulombEnergy = coulombConstant * atomCharges[i] * atomCharges[j] / r;
                    float coulombForce = coulombEnergy / r;
                    
                    // Morse势
                    float expFactor = expf(-morseAlpha[i] * (r - morseR0[i]));
                    float morseEnergy = morseDe[i] * (expFactor * expFactor - 2.0f * expFactor);
                    float morseForce = 2.0f * morseDe[i] * morseAlpha[i] * expFactor * (expFactor - 1.0f) / r;
                    
                    // 总能量和力
                    float totalEnergy = ljEnergy + coulombEnergy + morseEnergy;
                    float totalForce = ljForce + coulombForce + morseForce;
                    
                    float fx = totalForce * dx / r;
                    float fy = totalForce * dy / r;
                    float fz = totalForce * dz / r;
                    
                    atomForcesX[i] += fx;
                    atomForcesY[i] += fy;
                    atomForcesZ[i] += fz;
                    atomForcesX[j] -= fx;
                    atomForcesY[j] -= fy;
                    atomForcesZ[j] -= fz;
                    
                    atomEnergies[i] += totalEnergy * 0.5f;
                    atomEnergies[j] += totalEnergy * 0.5f;
                }
            }
        }
    }
    
    void integrateMotion() {
        // Velocity Verlet算法 - 第一部分
        for(int i = 0; i < ATOMS_COUNT; i++) {
            float mass = atomMasses[i];
            float halfDt = 0.5f * timeStep;
            
            // 更新速度（半步）
            atomVelocitiesX[i] += halfDt * atomForcesX[i] / mass;
            atomVelocitiesY[i] += halfDt * atomForcesY[i] / mass;
            atomVelocitiesZ[i] += halfDt * atomForcesZ[i] / mass;
            
            // 保存当前位置用于Verlet
            verletPositionX[i] = atomPositionsX[i];
            verletPositionY[i] = atomPositionsY[i];
            verletPositionZ[i] = atomPositionsZ[i];
            
            // 更新位置
            atomPositionsX[i] += timeStep * atomVelocitiesX[i];
            atomPositionsY[i] += timeStep * atomVelocitiesY[i];
            atomPositionsZ[i] += timeStep * atomVelocitiesZ[i];
        }
        
        // 计算新位置的力
        calculateForces();
        
        // Velocity Verlet算法 - 第二部分
        for(int i = 0; i < ATOMS_COUNT; i++) {
            float mass = atomMasses[i];
            float halfDt = 0.5f * timeStep;
            
            // 更新速度（另外半步）
            atomVelocitiesX[i] += halfDt * atomForcesX[i] / mass;
            atomVelocitiesY[i] += halfDt * atomForcesY[i] / mass;
            atomVelocitiesZ[i] += halfDt * atomForcesZ[i] / mass;
        }
        
        // 应用边界条件
        if(periodicBoundary) {
            applyPeriodicBoundary();
        }
        
        // 更新邻居列表
        if(currentStep % 10 == 0) {
            updateNeighborList();
        }
    }
    
    void applyPeriodicBoundary() {
        for(int i = 0; i < ATOMS_COUNT; i++) {
            atomPositionsX[i] = fmod(atomPositionsX[i] + boxSizeX, boxSizeX);
            atomPositionsY[i] = fmod(atomPositionsY[i] + boxSizeY, boxSizeY);
            atomPositionsZ[i] = fmod(atomPositionsZ[i] + boxSizeZ, boxSizeZ);
        }
    }
    
    void updateNeighborList() {
        for(int i = 0; i < ATOMS_COUNT; i++) {
            neighborCount[i] = 0;
        }
        
        for(int i = 0; i < ATOMS_COUNT; i++) {
            for(int j = i + 1; j < ATOMS_COUNT; j++) {
                float dx = atomPositionsX[j] - atomPositionsX[i];
                float dy = atomPositionsY[j] - atomPositionsY[i];
                float dz = atomPositionsZ[j] - atomPositionsZ[i];
                
                if(periodicBoundary) {
                    dx -= boxSizeX * roundf(dx / boxSizeX);
                    dy -= boxSizeY * roundf(dy / boxSizeY);
                    dz -= boxSizeZ * roundf(dz / boxSizeZ);
                }
                
                float r2 = dx*dx + dy*dy + dz*dz;
                
                if(r2 < cutoffDistance * cutoffDistance) {
                    neighborList[i][neighborCount[i]] = j;
                    neighborDistances[i][neighborCount[i]] = sqrtf(r2);
                    neighborCount[i]++;
                    
                    neighborList[j][neighborCount[j]] = i;
                    neighborDistances[j][neighborCount[j]] = sqrtf(r2);
                    neighborCount[j]++;
                }
            }
        }
    }
    
    void applyThermostat() {
        if(ensembleType == 1) {  // NVT系综
            // Berendsen热浴
            float currentTemp = calculateTemperature();
            float scaleFactor = sqrtf(1.0f + (temperature/currentTemp - 1.0f) * timeStep / thermostatParameter);
            
            for(int i = 0; i < ATOMS_COUNT; i++) {
                atomVelocitiesX[i] *= scaleFactor;
                atomVelocitiesY[i] *= scaleFactor;
                atomVelocitiesZ[i] *= scaleFactor;
            }
        }
    }
    
    void calculateProperties() {
        // 计算动能
        float ke = 0.0f;
        for(int i = 0; i < ATOMS_COUNT; i++) {
            float v2 = atomVelocitiesX[i]*atomVelocitiesX[i] + 
                      atomVelocitiesY[i]*atomVelocitiesY[i] + 
                      atomVelocitiesZ[i]*atomVelocitiesZ[i];
            ke += 0.5f * atomMasses[i] * v2;
        }
        
        // 计算势能
        float pe = 0.0f;
        for(int i = 0; i < ATOMS_COUNT; i++) {
            pe += atomEnergies[i];
        }
        
        kineticEnergy[currentStep] = ke;
        potentialEnergy[currentStep] = pe;
        totalEnergy[currentStep] = ke + pe;
        
        // 计算温度
        float currentTemp = calculateTemperature();
        temperatureHistory[currentStep] = currentTemp;
        
        // 计算压力
        float currentPressure = calculatePressure();
        pressureHistory[currentStep] = currentPressure;
    }
    
    float calculateTemperature() {
        float ke = kineticEnergy[currentStep];
        return 2.0f * ke / (3.0f * ATOMS_COUNT * 1.38e-23f);
    }
    
    float calculatePressure() {
        float virial = calculateVirial();
        float volume = boxSizeX * boxSizeY * boxSizeZ;
        return ATOMS_COUNT * 1.38e-23f * temperatureHistory[currentStep] / volume + virial / (3.0f * volume);
    }
    
    float calculateVirial() {
        float virial = 0.0f;
        for(int i = 0; i < ATOMS_COUNT; i++) {
            for(int j = 0; j < neighborCount[i]; j++) {
                int neighbor = neighborList[i][j];
                float r = neighborDistances[i][j];
                // 简化的维里计算
                virial += r * atomForcesX[i];  // 实际需要更精确的计算
            }
        }
        return virial;
    }
    
    void calculateCorrelationFunctions() {
        if(currentStep > equilibrationSteps) {
            int prodStep = currentStep - equilibrationSteps;
            
            // 计算径向分布函数
            calculateRadialDistributionFunction();
            
            // 计算均方位移
            calculateMeanSquaredDisplacement(prodStep);
            
            // 计算速度自相关函数
            calculateVelocityAutocorrelation(prodStep);
        }
    }
    
    void calculateRadialDistributionFunction() {
        float dr = cutoffDistance / GRID_POINTS;
        
        for(int i = 0; i < GRID_POINTS; i++) {
            radialDistribution[i] = 0.0f;
        }
        
        for(int i = 0; i < ATOMS_COUNT; i++) {
            for(int j = 0; j < neighborCount[i]; j++) {
                float r = neighborDistances[i][j];
                int bin = static_cast<int>(r / dr);
                if(bin < GRID_POINTS) {
                    radialDistribution[bin] += 1.0f;
                }
            }
        }
        
        // 归一化
        float norm = 4.0f * M_PI * dr * ATOMS_COUNT * density / (3.0f * boxSizeX * boxSizeY * boxSizeZ);
        for(int i = 0; i < GRID_POINTS; i++) {
            float r = (i + 0.5f) * dr;
            radialDistribution[i] /= norm * r * r;
        }
    }
    
    void calculateMeanSquaredDisplacement(int step) {
        if(step == 0) {
            // 保存初始位置
            for(int i = 0; i < ATOMS_COUNT; i++) {
                verletPositionX[i] = atomPositionsX[i];
                verletPositionY[i] = atomPositionsY[i];
                verletPositionZ[i] = atomPositionsZ[i];
            }
        } else {
            float msd = 0.0f;
            for(int i = 0; i < ATOMS_COUNT; i++) {
                float dx = atomPositionsX[i] - verletPositionX[i];
                float dy = atomPositionsY[i] - verletPositionY[i];
                float dz = atomPositionsZ[i] - verletPositionZ[i];
                
                if(periodicBoundary) {
                    dx -= boxSizeX * roundf(dx / boxSizeX);
                    dy -= boxSizeY * roundf(dy / boxSizeY);
                    dz -= boxSizeZ * roundf(dz / boxSizeZ);
                }
                
                msd += dx*dx + dy*dy + dz*dz;
            }
            meanSquaredDisplacement[step] = msd / ATOMS_COUNT;
        }
    }
    
    void calculateVelocityAutocorrelation(int step) {
        if(step == 0) {
            // 保存初始速度
            for(int i = 0; i < ATOMS_COUNT; i++) {
                verletPositionX[i] = atomVelocitiesX[i];  // 重用数组
                verletPositionY[i] = atomVelocitiesY[i];
                verletPositionZ[i] = atomVelocitiesZ[i];
            }
        } else {
            float vac = 0.0f;
            for(int i = 0; i < ATOMS_COUNT; i++) {
                vac += atomVelocitiesX[i] * verletPositionX[i] + 
                      atomVelocitiesY[i] * verletPositionY[i] + 
                      atomVelocitiesZ[i] * verletPositionZ[i];
            }
            velocityAutocorrelation[step] = vac / ATOMS_COUNT;
        }
    }
    
    void analyzeResults() {
        // 计算扩散系数
        diffusionCoefficient = 0.0f;
        int count = 0;
        for(int i = equilibrationSteps + 100; i < SIMULATION_STEPS - 100; i++) {
            float slope = (meanSquaredDisplacement[i+100] - meanSquaredDisplacement[i-100]) / 
                         (200 * timeStep);
            diffusionCoefficient += slope / 6.0f;  // 3维扩散
            count++;
        }
        diffusionCoefficient /= count;
        
        // 其他输运系数计算...
    }
    
