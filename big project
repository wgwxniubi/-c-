## 10 二维稳态热传导方程

```c
#include <iostream>
#include <cmath>
#include <iomanip>

int main() {
    // 物理参数
    double thermal_conductivity = 205.0;    // 热导率 (W/m·K) - 铜
    double density = 8960.0;                // 密度 (kg/m³)
    double specific_heat = 385.0;           // 比热容 (J/kg·K)
    double thermal_diffusivity = thermal_conductivity / (density * specific_heat);
    
    // 几何参数
    double plate_length_x = 1.0;           // 板长度 (m)
    double plate_length_y = 1.0;           // 板宽度 (m)
