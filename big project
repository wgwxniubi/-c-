## 4. 热传导模拟程序

```c
import numpy as np

class HeatTransferSimulation:
    def __init__(self, grid_size=20, time_steps=1000):
        self.grid_size = grid_size
        self.time_steps = time_steps
        self.thermal_diffusivity = 0.01
        self.delta_x = 0.1
        self.delta_t = 0.01
        
    def simulate_heat_transfer(self):
        # 温度场变量
        temperature = np.zeros((self.grid_size, self.grid_size))
        temperature_new = np.zeros((self.grid_size, self.grid_size))
        heat_flux_x = np.zeros((self.grid_size, self.grid_size))
        heat_flux_y = np.zeros((self.grid_size, self.grid_size))
        
        # 材料属性变量
        thermal_conductivity = np.zeros((self.grid_size, self.grid_size))
        specific_heat = np.zeros((self.grid_size, self.grid_size))
        density = np.zeros((self.grid_size, self.grid_size))
        
        # 边界条件变量
        boundary_temperature_top = 100.0
        boundary_temperature_bottom = 0.0
        boundary_temperature_left = 50.0
        boundary_temperature_right = 25.0
        
        # 热源变量
        heat_source = np.zeros((self.grid_size, self.grid_size))
        internal_energy = np.zeros((self.grid_size, self.grid_size))
        temperature_gradient_x = np.zeros((self.grid_size, self.grid_size))
        temperature_gradient_y = np.zeros((self.grid_size, self.grid_size))
        
        # 初始化温度场和材料属性
        for i in range(self.grid_size):
            for j in range(self.grid_size):
                thermal_conductivity[i][j] = 50.0  # W/m·K
                specific_heat[i][j] = 450.0  # J/kg·K
                density[i][j] = 7800.0  # kg/m³
                
                # 设置边界条件
                if i == 0:  # 上边界
                    temperature[i][j] = boundary_temperature_top
                elif i == self.grid_size-1:  # 下边界
                    temperature[i][j] = boundary_temperature_bottom
                elif j == 0:  # 左边界
                    temperature[i][j] = boundary_temperature_left
                elif j == self.grid_size-1:  # 右边界
                    temperature[i][j] = boundary_temperature_right
                else:
                    temperature[i][j] = 20.0  # 初始温度
                
                # 设置内部热源
                if 5 <= i <= 15 and 5 <= j <= 15:
                    heat_source[i][j] = 1000.0  # W/m³
        
        # 时间步进模拟
        for t in range(self.time_steps):
            total_energy = 0.0
            max_temperature = 0.0
            
            for i in range(1, self.grid_size-1):
                for j in range(1, self.grid_size-1):
                    # 计算温度梯度
                    temperature_gradient_x[i][j] = (temperature[i][j+1] - temperature[i][j-1]) / (2 * self.delta_x)
                    temperature_gradient_y[i][j] = (temperature[i+1][j] - temperature[i-1][j]) / (2 * self.delta_x)
                    
                    # 计算热通量（傅里叶定律）
                    heat_flux_x[i][j] = -thermal_conductivity[i][j] * temperature_gradient_x[i][j]
                    heat_flux_y[i][j] = -thermal_conductivity[i][j] * temperature_gradient_y[i][j]
                    
                    # 更新温度（热传导方程）
                    laplacian = (temperature[i][j+1] + temperature[i][j-1] + 
                                temperature[i+1][j] + temperature[i-1][j] - 4 * temperature[i][j]) / (self.delta_x ** 2)
                    
                    temperature_new[i][j] = (temperature[i][j] + 
                        self.thermal_diffusivity * self.delta_t * laplacian +
                        (heat_source[i][j] * self.delta_t) / 
                        (density[i][j] * specific_heat[i][j]))
                    
                    # 统计信息
                    total_energy += temperature_new[i][j] * density[i][j] * specific_heat[i][j]
                    max_temperature = max(max_temperature, temperature_new[i][j])
            
            # 更新温度场
            temperature = np.copy(temperature_new)
            
            if t % 100 == 0:
                print(f"时间步 {t}: 最高温度={max_temperature:.2f}°C, 总能量={total_energy:.2f}J")
        
        return temperature

# 运行模拟
if __name__ == "__main__":
    simulation = HeatTransferSimulation()
    final_temperature = simulation.simulate_heat_transfer()
    print(f"模拟完成，最终温度场形状: {final_temperature.shape}")
