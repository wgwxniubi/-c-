    double total_planet_mass = earth_mass + 0.107*earth_mass + 317.8*earth_mass + 95.16*earth_mass + 14.54*earth_mass;
    system_reduced_mass = (solar_mass * total_planet_mass) / (solar_mass + total_planet_mass);
    
