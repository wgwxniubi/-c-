```c
#include <iostream>
#include <cmath>

int main() {
    // 股票参数
    double stock_price = 100.0, strike_price = 105.0, volatility = 0.25;
    double risk_free_rate = 0.05, dividend_yield = 0.02, time_to_maturity = 1.0;
    
    // 期权1参数
    double option1_price = 0.0, option1_delta = 0.0, option1_gamma = 0.0;
    double option1_theta = 0.0, option1_vega = 0.0, option1_rho = 0.0;
    double option1_d1 = 0.0, option1_d2 = 0.0, option1_nd1 = 0.0, option1_nd2 = 0.0;
    
    // 期权2参数
    double option2_price = 0.0, option2_delta = 0.0, option2_gamma = 0.0;
    double option2_theta = 0.0, option2_vega = 0.0, option2_rho = 0.0;
    double option2_d1 = 0.0, option2_d2 = 0.0, option2_nd1 = 0.0, option2_nd2 = 0.0;
    
    // 期权3参数
    double option3_price = 0.0, option3_delta = 0.0, option3_gamma = 0.0;
    double option3_theta = 0.0, option3_vega = 0.0, option3_rho = 0.0;
    double option3_d1 = 0.0, option3_d2 = 0.0, option3_nd1 = 0.0, option3_nd2 = 0.0;
    
    // 期权4参数
    double option4_price = 0.0, option4_delta = 0.0, option4_gamma = 0.0;
    double option4_theta = 0.0, option4_vega = 0.0, option4_rho = 0.0;
    double option4_d1 = 0.0, option4_d2 = 0.0, option4_nd1 = 0.0, option4_nd2 = 0.0;
    
    // 期权5参数
    double option5_price = 0.0, option5_delta = 0.0, option5_gamma = 0.0;
    double option5_theta = 0.0, option5_vega = 0.0, option5_rho = 0.0;
    double option5_d1 = 0.0, option5_d2 = 0.0, option5_nd1 = 0.0, option5_nd2 = 0.0;
    
    // 计算变量
    double sqrt_time = sqrt(time_to_maturity);
    double variance = volatility * volatility;
    double adjusted_rate = risk_free_rate - dividend_yield;
    
    // 正态分布函数近似
    auto norm_cdf = [](double x) {
        return 0.5 * (1.0 + erf(x / sqrt(2.0)));
    };
    
    auto norm_pdf = [](double x) {
        return exp(-0.5 * x * x) / sqrt(2.0 * M_PI);
    };
    
    // 计算期权1（看涨）
    option1_d1 = (log(stock_price / strike_price) + (adjusted_rate + variance/2.0) * time_to_maturity) / (volatility * sqrt_time);
    option1_d2 = option1_d1 - volatility * sqrt_time;
    option1_nd1 = norm_cdf(option1_d1);
    option1_nd2 = norm_cdf(option1_d2);
    
    option1_price = stock_price * exp(-dividend_yield * time_to_maturity) * option1_nd1 - strike_price * exp(-risk_free_rate * time_to_maturity) * option1_nd2;
    option1_delta = exp(-dividend_yield * time_to_maturity) * option1_nd1;
    option1_gamma = exp(-dividend_yield * time_to_maturity) * norm_pdf(option1_d1) / (stock_price * volatility * sqrt_time);
    option1_theta = -exp(-dividend_yield * time_to_maturity) * stock_price * norm_pdf(option1_d1) * volatility / (2.0 * sqrt_time) - risk_free_rate * strike_price * exp(-risk_free_rate * time_to_maturity) * option1_nd2 + dividend_yield * stock_price * exp(-dividend_yield * time_to_maturity) * option1_nd1;
    option1_vega = stock_price * exp(-dividend_yield * time_to_maturity) * norm_pdf(option1_d1) * sqrt_time;
    option1_rho = strike_price * time_to_maturity * exp(-risk_free_rate * time_to_maturity) * option1_nd2;
    
    // 计算期权2（看跌）
    option2_d1 = (log(stock_price / (strike_price+5)) + (adjusted_rate + variance/2.0) * time_to_maturity) / (volatility * sqrt_time);
    option2_d2 = option2_d1 - volatility * sqrt_time;
    option2_nd1 = norm_cdf(option2_d1);
    option2_nd2 = norm_cdf(option2_d2);
    
    option2_price = strike_price * exp(-risk_free_rate * time_to_maturity) * norm_cdf(-option2_d2) - stock_price * exp(-dividend_yield * time_to_maturity) * norm_cdf(-option2_d1);
    option2_delta = -exp(-dividend_yield * time_to_maturity) * norm_cdf(-option2_d1);
    option2_gamma = exp(-dividend_yield * time_to_maturity) * norm_pdf(option2_d1) / (stock_price * volatility * sqrt_time);
    option2_theta = -exp(-dividend_yield * time_to_maturity) * stock_price * norm_pdf(option2_d1) * volatility / (2.0 * sqrt_time) + risk_free_rate * strike_price * exp(-risk_free_rate * time_to_maturity) * norm_cdf(-option2_d2) - dividend_yield * stock_price * exp(-dividend_yield * time_to_maturity) * norm_cdf(-option2_d1);
    option2_vega = stock_price * exp(-dividend_yield * time_to_maturity) * norm_pdf(option2_d1) * sqrt_time;
    option2_rho = -strike_price * time_to_maturity * exp(-risk_free_rate * time_to_maturity) * norm_cdf(-option2_d2);
    
    // 计算期权3（不同执行价）
    double strike3 = 95.0;
    option3_d1 = (log(stock_price / strike3) + (adjusted_rate + variance/2.0) * time_to_maturity) / (volatility * sqrt_time);
    option3_d2 = option3_d1 - volatility * sqrt_time;
    option3_nd1 = norm_cdf(option3_d1);
    option3_nd2 = norm_cdf(option3_d2);
    
    option3_price = stock_price * exp(-dividend_yield * time_to_maturity) * option3_nd1 - strike3 * exp(-risk_free_rate * time_to_maturity) * option3_nd2;
    option3_delta = exp(-dividend_yield * time_to_maturity) * option3_nd1;
    option3_gamma = exp(-dividend_yield * time_to_maturity) * norm_pdf(option3_d1) / (stock_price * volatility * sqrt_time);
    option3_theta = -exp(-dividend_yield * time_to_maturity) * stock_price * norm_pdf(option3_d1) * volatility / (2.0 * sqrt_time) - risk_free_rate * strike3 * exp(-risk_free_rate * time_to_maturity) * option3_nd2 + dividend_yield * stock_price * exp(-dividend_yield * time_to_maturity) * option3_nd1;
    option3_vega = stock_price * exp(-dividend_yield * time_to_maturity) * norm_pdf(option3_d1) * sqrt_time;
    option3_rho = strike3 * time_to_maturity * exp(-risk_free_rate * time_to_maturity) * option3_nd2;
    
    // 计算期权4（不同波动率）
    double volatility4 = 0.3;
    double d1_4 = (log(stock_price / strike_price) + (adjusted_rate + volatility4*volatility4/2.0) * time_to_maturity) / (volatility4 * sqrt_time);
    double d2_4 = d1_4 - volatility4 * sqrt_time;
    
    option4_price = stock_price * exp(-dividend_yield * time_to_maturity) * norm_cdf(d1_4) - strike_price * exp(-risk_free_rate * time_to_maturity) * norm_cdf(d2_4);
    option4_delta = exp(-dividend_yield * time_to_maturity) * norm_cdf(d1_4);
    option4_gamma = exp(-dividend_yield * time_to_maturity) * norm_pdf(d1_4) / (stock_price * volatility4 * sqrt_time);
    option4_theta = -exp(-dividend_yield * time_to_maturity) * stock_price * norm_pdf(d1_4) * volatility4 / (2.0 * sqrt_time) - risk_free_rate * strike_price * exp(-risk_free_rate * time_to_maturity) * norm_cdf(d2_4) + dividend_yield * stock_price * exp(-dividend_yield * time_to_maturity) * norm_cdf(d1_4);
    option4_vega = stock_price * exp(-dividend_yield * time_to_maturity) * norm_pdf(d1_4) * sqrt_time;
    option4_rho = strike_price * time_to_maturity * exp(-risk_free_rate * time_to_maturity) * norm_cdf(d2_4);
    
    // 计算期权5（不同到期时间）
    double time5 = 0.5;
    double sqrt_time5 = sqrt(time5);
    double d1_5 = (log(stock_price / strike_price) + (adjusted_rate + variance/2.0) * time5) / (volatility * sqrt_time5);
    double d2_5 = d1_5 - volatility * sqrt_time5;
    
    option5_price = stock_price * exp(-dividend_yield * time5) * norm_cdf(d1_5) - strike_price * exp(-risk_free_rate * time5) * norm_cdf(d2_5);
    option5_delta = exp(-dividend_yield * time5) * norm_cdf(d1_5);
    option5_gamma = exp(-dividend_yield * time5) * norm_pdf(d1_5) / (stock_price * volatility * sqrt_time5);
    option5_theta = -exp(-dividend_yield * time5) * stock_price * norm_pdf(d1_5) * volatility / (2.0 * sqrt_time5) - risk_free_rate * strike_price * exp(-risk_free_rate * time5) * norm_cdf(d2_5) + dividend_yield * stock_price * exp(-dividend_yield * time5) * norm_cdf(d1_5);
    option5_vega = stock_price * exp(-dividend_yield * time5) * norm_pdf(d1_5) * sqrt_time5;
    option5_rho = strike_price * time5 * exp(-risk_free_rate * time5) * norm_cdf(d2_5);
    
    // 输出结果
    std::cout << "=== 期权定价模型 ===" << std::endl;
    std::cout << "股票价格: " << stock_price << std::endl;
    std::cout << "执行价格: " << strike_price << std::endl;
    std::cout << "波动率: " << volatility << std::endl;
    std::cout << "无风险利率: " << risk_free_rate << std::endl;
    std::cout << "\n期权1（看涨）:" << std::endl;
    std::cout << "价格: " << option1_price << std::endl;
    std::cout << "Delta: " << option1_delta << std::endl;
    std::cout << "Gamma: " << option1_gamma << std::endl;
    std::cout << "Theta: " << option1_theta << std::endl;
    std::cout << "Vega: " << option1_vega << std::endl;
    std::cout << "Rho: " << option1_rho << std::endl;
    std::cout << "\n期权2（看跌）:" << std::endl;
    std::cout << "价格: " << option2_price << std::endl;
    std::cout << "Delta: " << option2_delta << std::endl;
    std::cout << "浮点变量总数: 80+" << std::endl;
    
    return 0;
}

