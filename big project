        std::cout << "最终动量X: " << std::setprecision(8) << momentumX[SIMULATION_STEPS-1] << " kg·m/s" << std::endl;
        std::cout << "浮点变量总数: 100+" << std::endl;
        std::cout << "==========================" << std::endl;
    }
};

