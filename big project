    double signal2_magnitude[1000], signal2_phase_spectrum[1000];
    double signal2_dc = 0.0, signal2_rms = 0.0, signal2_power = 0.0;
    
    // 信号3参数
    double signal3_amplitude = 2.0, signal3_frequency = 200.0, signal3_phase = M_PI/2;
