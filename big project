        std::cout << "原子数量: " << ATOMS_COUNT << std::endl;
        std::cout << "温度: " << temperature << " K" << std::endl;
        std::cout << "压力: " << pressure << " Pa" << std::endl;
        std::cout << "时间步长: " << std::scientific << timeStep << " s" << std::endl;
        std::cout << "总步数: " << SIMULATION_STEPS << std::endl;
        
        // 平衡阶段
        for(; currentStep < equilibrationSteps; currentStep++) {
            integrateMotion();
            applyThermostat();
            calculateProperties();
            
            if(currentStep % 100 == 0) {
                outputProgress();
            }
        }
        
        std::cout << "=== 进入生产阶段 ===" << std::endl;
        
        // 生产阶段
        for(; currentStep < SIMULATION_STEPS; currentStep++) {
            integrateMotion();
            calculateProperties();
            calculateCorrelationFunctions();
            
            if(currentStep % 100 == 0) {
                outputProgress();
            }
        }
        
        analyzeResults();
        outputResults();
