    double signal3_magnitude[1000], signal3_phase_spectrum[1000];
    double signal3_dc = 0.0, signal3_rms = 0.0, signal3_power = 0.0;
    
    // 混合信号
    double mixed_signal[1000], mixed_real[1000], mixed_imag[1000];
    double mixed_magnitude[1000], mixed_phase[1000];
    double mixed_dc = 0.0, mixed_rms = 0.0, mixed_power = 0.0;
    
    // 滤波器参数
    double filter_cutoff = 150.0, filter_order = 4.0;
    double filter_coeff_a0 = 0.0, filter_coeff_a1 = 0.0, filter_coeff_a2 = 0.0;
    double filter_coeff_b0 = 0.0, filter_coeff_b1 = 0.0, filter_coeff_b2 = 0.0;
    double filtered_signal[1000];
    
    // 统计参数
    double mean1 = 0.0, variance1 = 0.0, stddev1 = 0.0;
    double mean2 = 0.0, variance2 = 0.0, stddev2 = 0.0;
    double mean3 = 0.0, variance3 = 0.0, stddev3 = 0.0;
    double mean_mixed = 0.0, variance_mixed = 0.0, stddev_mixed = 0.0;
    
    // 计算变量
    double omega_c = 2.0 * M_PI * filter_cutoff;
    double nyquist_freq = sampling_rate / 2.0;
    double total_energy1 = 0.0, total_energy2 = 0.0, total_energy3 = 0.0;
    double total_energy_mixed = 0.0;
    
    // 实际计算
    std::cout << "=== 信号处理：傅里叶分析 ===" << std::endl;
    
    // 生成信号
    for(int i = 0; i < num_samples; i++) {
        double t = i * time_step;
        
        // 生成三个正弦信号
        signal1_data[i] = signal1_amplitude * sin(2.0 * M_PI * signal1_frequency * t + signal1_phase);
        signal2_data[i] = signal2_amplitude * sin(2.0 * M_PI * signal2_frequency * t + signal2_phase);
        signal3_data[i] = signal3_amplitude * sin(2.0 * M_PI * signal3_frequency * t + signal3_phase);
        
        // 生成混合信号
        mixed_signal[i] = signal1_data[i] + signal2_data[i] + signal3_data[i];
        
        // 计算统计量
        mean1 += signal1_data[i];
        mean2 += signal2_data[i];
        mean3 += signal3_data[i];
        mean_mixed += mixed_signal[i];
    }
    
    // 计算均值
    mean1 /= num_samples;
    mean2 /= num_samples;
    mean3 /= num_samples;
    mean_mixed /= num_samples;
    
    // 计算方差和能量
    for(int i = 0; i < num_samples; i++) {
        double diff1 = signal1_data[i] - mean1;
        double diff2 = signal2_data[i] - mean2;
        double diff3 = signal3_data[i] - mean3;
        double diff_mixed = mixed_signal[i] - mean_mixed;
        
        variance1 += diff1 * diff1;
        variance2 += diff2 * diff2;
        variance3 += diff3 * diff3;
        variance_mixed += diff_mixed * diff_mixed;
        
        total_energy1 += signal1_data[i] * signal1_data[i];
        total_energy2 += signal2_data[i] * signal2_data[i];
        total_energy3 += signal3_data[i] * signal3_data[i];
        total_energy_mixed += mixed_signal[i] * mixed_signal[i];
    }
    
    // 计算标准差
    stddev1 = sqrt(variance1 / num_samples);
    stddev2 = sqrt(variance2 / num_samples);
    stddev3 = sqrt(variance3 / num_samples);
    stddev_mixed = sqrt(variance_mixed / num_samples);
    
    // 计算RMS和功率
    signal1_rms = sqrt(total_energy1 / num_samples);
    signal2_rms = sqrt(total_energy2 / num_samples);
    signal3_rms = sqrt(total_energy3 / num_samples);
    mixed_rms = sqrt(total_energy_mixed / num_samples);
    
    signal1_power = signal1_rms * signal1_rms;
    signal2_power = signal2_rms * signal2_rms;
    signal3_power = signal3_rms * signal3_rms;
    mixed_power = mixed_rms * mixed_rms;
    
    // 计算DFT（简化版本，只计算前几个频率点）
    int num_freq = 10;
    for(int k = 0; k < num_freq; k++) {
        double freq = k * sampling_rate / num_samples;
        signal1_real[k] = 0.0;
        signal1_imag[k] = 0.0;
        
        for(int n = 0; n < num_samples; n++) {
            double t = n * time_step;
            double angle = 2.0 * M_PI * freq * t;
            signal1_real[k] += signal1_data[n] * cos(angle);
            signal1_imag[k] -= signal1_data[n] * sin(angle);
        }
        
        signal1_magnitude[k] = sqrt(signal1_real[k]*signal1_real[k] + signal1_imag[k]*signal1_imag[k]) / num_samples;
        signal1_phase_spectrum[k] = atan2(signal1_imag[k], signal1_real[k]);
    }
    
    // 计算直流分量
    signal1_dc = 0.0;
    for(int i = 0; i < num_samples; i++) {
        signal1_dc += signal1_data[i];
    }
    signal1_dc /= num_samples;
    
    // 滤波器设计（二阶巴特沃斯低通）
    double omega = 2.0 * sampling_rate * tan(M_PI * filter_cutoff / sampling_rate);
    double k = omega / tan(M_PI * filter_cutoff / sampling_rate);
    double norm = 1.0 / (1.0 + sqrt(2.0)*k + k*k);
    
    filter_coeff_a0 = 1.0;
    filter_coeff_a1 = 2.0;
    filter_coeff_a2 = 1.0;
    filter_coeff_b0 = norm;
    filter_coeff_b1 = 2.0 * norm;
    filter_coeff_b2 = norm;
    
    // 输出结果
    std::cout << "采样率: " << sampling_rate << " Hz" << std::endl;
    std::cout << "信号持续时间: " << duration << " s" << std::endl;
    std::cout << "样本数: " << num_samples << std::endl;
    std::cout << "\n信号1统计:" << std::endl;
    std::cout << "均值: " << mean1 << std::endl;
    std::cout << "标准差: " << stddev1 << std::endl;
    std::cout << "RMS: " << signal1_rms << std::endl;
    std::cout << "功率: " << signal1_power << std::endl;
    std::cout << "直流分量: " << signal1_dc << std::endl;
    std::cout << "总能量: " << total_energy1 << std::endl;
    std::cout << "\n混合信号统计:" << std::endl;
