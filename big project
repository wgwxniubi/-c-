private:
    void applyBoundaryConditions() {
        // 入口边界条件
        for(int j = 0; j < GRID_SIZE_Y; j++) {
            for(int k = 0; k < GRID_SIZE_Z; k++) {
                velocityX[0][j][k] = 1.0f; // 均匀入口速度
                velocityY[0][j][k] = 0.0f;
                velocityZ[0][j][k] = 0.0f;
                pressure[0][j][k] = 101325.0f;
            }
        }
        
        // 出口边界条件
        for(int j = 0; j < GRID_SIZE_Y; j++) {
            for(int k = 0; k < GRID_SIZE_Z; k++) {
                pressure[GRID_SIZE_X-1][j][k] = 101325.0f;
            }
        }
        
        // 壁面边界条件（无滑移）
        for(int i = 0; i < GRID_SIZE_X; i++) {
            for(int k = 0; k < GRID_SIZE_Z; k++) {
                velocityX[i][0][k] = 0.0f;
                velocityY[i][0][k] = 0.0f;
                velocityZ[i][0][k] = 0.0f;
                velocityX[i][GRID_SIZE_Y-1][k] = 0.0f;
                velocityY[i][GRID_SIZE_Y-1][k] = 0.0f;
                velocityZ[i][GRID_SIZE_Y-1][k] = 0.0f;
            }
        }
    }
    
    void calculateFluxes() {
        // 计算对流和扩散通量
        for(int i = 1; i < GRID_SIZE_X-1; i++) {
            for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                    // 质量通量
                    massFluxX[i][j][k] = density[i][j][k] * velocityX[i][j][k];
                    massFluxY[i][j][k] = density[i][j][k] * velocityY[i][j][k];
                    massFluxZ[i][j][k] = density[i][j][k] * velocityZ[i][j][k];
                    
                    // 对流项
                    float convX = calculateConvectionX(i, j, k);
                    float convY = calculateConvectionY(i, j, k);
                    float convZ = calculateConvectionZ(i, j, k);
                    
                    // 扩散项
                    float diffX = calculateDiffusionX(i, j, k);
                    float diffY = calculateDiffusionY(i, j, k);
                    float diffZ = calculateDiffusionZ(i, j, k);
                    
                    // 临时速度（忽略压力梯度）
                    velocityX_temp[i][j][k] = velocityX[i][j][k] + 
                                            timeStep * (diffX - convX);
                    velocityY_temp[i][j][k] = velocityY[i][j][k] + 
                                            timeStep * (diffY - convY);
                    velocityZ_temp[i][j][k] = velocityZ[i][j][k] + 
                                            timeStep * (diffZ - convZ);
                }
            }
        }
    }
    
    float calculateConvectionX(int i, int j, int k) {
        // 简化的对流项计算
        float u = velocityX[i][j][k];
        float v = velocityY[i][j][k];
        float w = velocityZ[i][j][k];
        
        float dudx = (velocityX[i+1][j][k] - velocityX[i-1][j][k]) / (2.0f * gridSpacingX);
        float dudy = (velocityX[i][j+1][k] - velocityX[i][j-1][k]) / (2.0f * gridSpacingY);
        float dudz = (velocityX[i][j][k+1] - velocityX[i][j][k-1]) / (2.0f * gridSpacingZ);
        
        return u * dudx + v * dudy + w * dudz;
    }
    
    float calculateDiffusionX(int i, int j, int k) {
        // 简化的扩散项计算
        float nu = viscosity[i][j][k] / density[i][j][k];
        
        float d2udx2 = (velocityX[i+1][j][k] - 2*velocityX[i][j][k] + velocityX[i-1][j][k]) / 
                      (gridSpacingX * gridSpacingX);
        float d2udy2 = (velocityX[i][j+1][k] - 2*velocityX[i][j][k] + velocityX[i][j-1][k]) / 
                      (gridSpacingY * gridSpacingY);
        float d2udz2 = (velocityX[i][j][k+1] - 2*velocityX[i][j][k] + velocityX[i][j][k-1]) / 
                      (gridSpacingZ * gridSpacingZ);
        
        return nu * (d2udx2 + d2udy2 + d2udz2);
    }
    
    // 类似实现Y和Z方向的对流扩散项计算
    float calculateConvectionY(int i, int j, int k) { return 0.0f; }
    float calculateConvectionZ(int i, int j, int k) { return 0.0f; }
    float calculateDiffusionY(int i, int j, int k) { return 0.0f; }
    float calculateDiffusionZ(int i, int j, int k) { return 0.0f; }
    
    void solveMomentumEquations() {
        // 求解动量方程（简化实现）
        for(int i = 1; i < GRID_SIZE_X-1; i++) {
            for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                    // 压力梯度项
                    float dpdx = (pressure[i+1][j][k] - pressure[i-1][j][k]) / (2.0f * gridSpacingX);
                    
                    // 更新速度
                    velocityX_temp[i][j][k] -= timeStep * dpdx / density[i][j][k];
                }
            }
        }
    }
    
    void solvePressureCorrection() {
        // 压力修正方程（简化Poisson方程求解）
        float maxResidual = 1.0f;
        int pressureIterations = 0;
        
        while(maxResidual > 1e-6f && pressureIterations < 100) {
            maxResidual = 0.0f;
            
            for(int i = 1; i < GRID_SIZE_X-1; i++) {
                for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                    for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                        // 连续性方程残差
                        float divU = (velocityX_temp[i+1][j][k] - velocityX_temp[i-1][j][k]) / (2.0f * gridSpacingX) +
                                   (velocityY_temp[i][j+1][k] - velocityY_temp[i][j-1][k]) / (2.0f * gridSpacingY) +
                                   (velocityZ_temp[i][j][k+1] - velocityZ_temp[i][j][k-1]) / (2.0f * gridSpacingZ);
                        
                        // 压力修正
                        float pressureCorrection = -divU * density[i][j][k] * gridSpacingX * gridSpacingY / timeStep;
                        pressure_temp[i][j][k] = pressure[i][j][k] + 0.1f * pressureCorrection;
                        
                        maxResidual = fmax(maxResidual, fabs(divU));
                    }
                }
            }
            
            pressureIterations++;
        }
    }
    
    void correctVelocityField() {
        // 速度修正
        for(int i = 1; i < GRID_SIZE_X-1; i++) {
            for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                    float dpdx = (pressure_temp[i+1][j][k] - pressure_temp[i-1][j][k]) / (2.0f * gridSpacingX);
                    
                    velocityX[i][j][k] = velocityX_temp[i][j][k] - 
                                       timeStep * dpdx / density[i][j][k];
                    velocityY[i][j][k] = velocityY_temp[i][j][k];
                    velocityZ[i][j][k] = velocityZ_temp[i][j][k];
                    pressure[i][j][k] = pressure_temp[i][j][k];
                }
            }
        }
    }
    
    void solveEnergyEquation() {
        // 求解能量方程（简化实现）
        for(int i = 1; i < GRID_SIZE_X-1; i++) {
            for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                    // 简化的温度更新
                    float dTdx = (temperature[i+1][j][k] - temperature[i-1][j][k]) / (2.0f * gridSpacingX);
                    temperature[i][j][k] -= timeStep * velocityX[i][j][k] * dTdx;
                }
            }
        }
    }
    
    void updateTurbulenceModel() {
        // 更新湍流模型变量（简化实现）
        for(int i = 1; i < GRID_SIZE_X-1; i++) {
            for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                    // 简化的湍流动能更新
                    float s11 = (velocityX[i+1][j][k] - velocityX[i-1][j][k]) / (2.0f * gridSpacingX);
                    turbulentKineticEnergy[i][j][k] = 0.1f * s11 * s11;
                }
            }
        }
    }
    
    void calculateResiduals() {
        // 计算连续性方程残差
        float maxContinuityResidual = 0.0f;
        for(int i = 1; i < GRID_SIZE_X-1; i++) {
            for(int j = 1; j < GRID_SIZE_Y-1; j++) {
                for(int k = 1; k < GRID_SIZE_Z-1; k++) {
                    float divU = (velocityX[i+1][j][k] - velocityX[i-1][j][k]) / (2.0f * gridSpacingX) +
                               (velocityY[i][j+1][k] - velocityY[i][j-1][k]) / (2.0f * gridSpacingY) +
                               (velocityZ[i][j][k+1] - velocityZ[i][j][k-1]) / (2.0f * gridSpacingZ);
                    maxContinuityResidual = fmax(maxContinuityResidual, fabs(divU));
                }
            }
        }
        
        residualContinuity[currentIteration/outputFrequency] = maxContinuityResidual;
    }
    
    void outputProgress() {
        std::cout << "迭代步: " << currentIteration 
                  << ", 连续性残差: " << std::scientific << residualContinuity[currentIteration/outputFrequency] 
                  << std::fixed << std::endl;
    }
    
    void outputResults() {
        std::cout << "=== CFD计算完成 ===" << std::endl;
        
        // 计算流量统计
        float totalMassFlow = 0.0f;
        float maxVelocity = 0.0f;
        
        for(int i = 0; i < GRID_SIZE_X; i++) {
            for(int j = 0; j < GRID_SIZE_Y; j++) {
                for(int k = 0; k < GRID_SIZE_Z; k++) {
                    float vel = sqrtf(velocityX[i][j][k]*velocityX[i][j][k] +
                                    velocityY[i][j][k]*velocityY[i][j][k] +
                                    velocityZ[i][j][k]*velocityZ[i][j][k]);
                    maxVelocity = fmax(maxVelocity, vel);
                    
                    if(i == GRID_SIZE_X/2) {
                        totalMassFlow += density[i][j][k] * velocityX[i][j][k] * 
                                       gridSpacingY * gridSpacingZ;
                    }
                }
            }
        }
        
        std::cout << "最大速度: " << maxVelocity << " m/s" << std::endl;
        std::cout << "总质量流量: " << totalMassFlow << " kg/s" << std::endl;
        std::cout << "浮点变量总数: 100+" << std::endl;
        std::cout << "==========================" << std::endl;
    }
};

int main() {
    FluidDynamicsSolver cfd;
    cfd.solveNavierStokes();
    return 0;
