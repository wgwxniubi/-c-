                    atomVelocitiesY[atomIndex] = sigma * gaussianRandom();
                    atomVelocitiesZ[atomIndex] = sigma * gaussianRandom();
                    
                    atomMasses[atomIndex] = 1.67e-27f;  // 氢原子质量
                    atomCharges[atomIndex] = 1.6e-19f;  // 基本电荷
                    
                    // Morse势参数
                    morseDe[atomIndex] = 1.65e-21f;
                    morseAlpha[atomIndex] = 1.0e10f;
