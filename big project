    float gaussianRandom() {
        // 简化的高斯随机数生成
        static bool hasSpare = false;
        static float spare;
        
        if(hasSpare) {
            hasSpare = false;
            return spare;
        }
        
        hasSpare = true;
        static float u, v, s;
        do {
            u = (rand() / ((float)RAND_MAX)) * 2.0f - 1.0f;
            v = (rand() / ((float)RAND_MAX)) * 2.0f - 1.0f;
            s = u * u + v * v;
        } while(s >= 1.0f || s == 0.0f);
        
        s = sqrtf(-2.0f * logf(s) / s);
        spare = v * s;
        return u * s;
    }
